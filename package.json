{
  "name": "time-attendance",
  "private": true,
  "workspaces": [
    "backend",
    "web-admin",
    "web-dev",
    "mobile-app"
  ],
  "scripts": {
    "install-all": "npm install",
    "build": "npm run build --workspaces --if-present",
    "start": "node backend/server.js",
    "start-backend": "npm --workspace backend run dev",
    "start-web": "npm --workspace web-admin run dev",
    "start-mobile": "npm --workspace mobile-app run dev",
    "build-mobile": "npm --workspace mobile-app run build",
    "apk-mobile": "npm --workspace mobile-app run apk",
    "clean": "node -e \"const fs=require('fs'); ['web-admin','web-dev','mobile-app'].forEach(d=>{['dist','dist-test'].forEach(f=>{const p=d+'/'+f; if(fs.existsSync(p)) fs.rmSync(p,{recursive:true,force:true})})})\"",
    "dev:full": "node scripts/start-dev.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0"
  },
  "version": "1.0.0"
}